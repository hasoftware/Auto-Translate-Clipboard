<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="AutoTranslate.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AutoTranslate"
    Title="Settings"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <ScrollViewer x:Name="SettingsScroll" MaxHeight="460" HorizontalScrollMode="Disabled"
                  HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="18" MinWidth="340" Padding="0,0,12,0">

        <StackPanel Spacing="6">
            <TextBlock Text="Theme" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <ComboBox x:Name="ThemeCombo" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="System" />
                <ComboBoxItem Content="Light" />
                <ComboBoxItem Content="Dark" />
            </ComboBox>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Popup hotkey" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <Button x:Name="HotkeyBtn" HorizontalAlignment="Stretch" Click="OnCaptureHotkey" />
            <TextBlock x:Name="HotkeyHint"
                       Text="Click the button, then press a key combination (e.g. Ctrl+Shift+T)."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <ToggleSwitch x:Name="StartupSwitch" Header="Run at startup" />

        <StackPanel Spacing="6">
            <TextBlock Text="Languages shown in dropdowns" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBlock Text="Tick only the languages you use — the rest stay hidden from the dropdowns."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Select all" Click="OnSelectAllLangs" />
                <Button Content="Clear" Click="OnClearLangs" />
            </StackPanel>
            <ListView x:Name="LangList" SelectionMode="None" Height="200"
                      BorderThickness="1" CornerRadius="6"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:LangItem">
                        <CheckBox Content="{x:Bind Name}" IsChecked="{x:Bind Checked, Mode=TwoWay}" MinWidth="0" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

    </StackPanel>
    </ScrollViewer>
</ContentDialog>
